    <style>
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      :root {
        --navy: #083b70;
        --navy-dark: #062c54;
        --green: #1f6f2a;
        --green-dark: #0f3d22;
        --blue: #4f8fd8;
        --blue-light: #dceefe;
        --green-soft: #eef7ef;
        --cream: #f7faf6;
        --white: #ffffff;
        --text: #1f2933;
        --muted: #53616c;
        --line: #dfe9e0;
        --shadow: 0 18px 45px rgba(8, 59, 112, 0.12);
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: Arial, sans-serif;
        color: var(--text);
        background: var(--cream);
        line-height: 1.6;
        overflow-x: hidden;
      }

      img {
        max-width: 100%;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      button {
        font-family: inherit;
      }

      section {
        padding: 82px 7%;
        scroll-margin-top: 104px;
      }

      header {
        background: rgba(255, 255, 255, 0.97);
        color: var(--navy);
        padding: 12px 7%;
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: sticky;
        top: 0;
        z-index: 20;
        box-shadow: 0 6px 22px rgba(8, 59, 112, 0.12);
        backdrop-filter: blur(12px);
      }

      .brand-wrap {
        display: flex;
        align-items: center;
        gap: 20px;
      }

      .brand {
        display: flex;
        align-items: center;
        gap: 12px;
      }

      .brand img {
        width: 58px;
        height: 58px;
        object-fit: contain;
      }

      .brand-text {
        display: flex;
        flex-direction: column;
        line-height: 1.1;
      }

      .brand-text strong {
        font-size: 1.2rem;
        color: var(--navy);
        letter-spacing: -0.02em;
      }

      .brand-text span {
        font-size: 0.85rem;
        color: var(--green);
        font-weight: 800;
      }

      .header-phone {
        color: var(--navy);
        font-weight: 900;
        font-size: 1rem;
        padding: 10px 15px;
        border-radius: 14px;
        background: var(--green-soft);
        border: 1px solid #d9eadf;
        transition: 0.2s ease;
        white-space: nowrap;
      }

      .header-phone:hover {
        background: var(--blue);
        color: white;
        transform: translateY(-1px);
      }

      nav {
        display: flex;
        gap: 22px;
        font-size: 0.95rem;
        font-weight: 800;
      }

      nav a {
        transition: 0.2s ease;
      }

      nav a:hover {
        color: var(--green);
      }

      .hero {
        min-height: 82vh;
        padding: 82px 7%;
        display: grid;
        grid-template-columns: minmax(0, 1fr) 410px;
        gap: 56px;
        align-items: center;
        background:
          linear-gradient(
            90deg,
            rgba(6, 44, 84, 0.9) 0%,
            rgba(12, 68, 45, 0.78) 55%,
            rgba(12, 68, 45, 0.58) 100%
          ),
          url("/Truck.webp");
        background-size: cover;
        background-position: 38% center;
        color: white;
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(255, 255, 255, 0.12);
        border: 1px solid rgba(255, 255, 255, 0.25);
        color: white;
        padding: 8px 12px;
        border-radius: 999px;
        font-weight: 800;
        margin-bottom: 18px;
      }

      .hero h1 {
        font-size: clamp(2.6rem, 4.6vw, 4.45rem);
        line-height: 1.04;
        letter-spacing: -0.045em;
        margin-bottom: 24px;
        max-width: 790px;
      }

      .hero p {
        font-size: 1.1rem;
        max-width: 640px;
        margin-bottom: 32px;
        line-height: 1.75;
        color: rgba(255, 255, 255, 0.93);
      }

      .buttons {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
      }

      .btn {
        min-height: 48px;
        padding: 14px 24px;
        border-radius: 14px;
        font-weight: 900;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: 0.2s ease;
      }

      .btn-primary {
        background: var(--blue);
        color: white;
        box-shadow: 0 12px 26px rgba(79, 143, 216, 0.28);
      }

      .btn-primary:hover {
        background: var(--navy);
        transform: translateY(-2px);
      }

      .btn-secondary {
        border: 2px solid rgba(255, 255, 255, 0.9);
        color: white;
      }

      .btn-secondary:hover {
        background: white;
        color: var(--navy);
        transform: translateY(-2px);
      }

      .hero-card {
        background: rgba(255, 255, 255, 0.97);
        color: var(--text);
        padding: 32px;
        border-radius: 26px;
        box-shadow: 0 24px 55px rgba(0, 0, 0, 0.22);
        border: 1px solid rgba(255, 255, 255, 0.74);
        border-top: 7px solid var(--blue);
      }

      .hero-card img {
        width: 118px;
        height: auto;
        display: block;
        margin: 0 auto 18px;
      }

      .hero-card h2 {
        margin-bottom: 18px;
        color: var(--navy);
        text-align: center;
        font-size: 1.45rem;
        line-height: 1.25;
      }

      .hero-card ul {
        list-style: none;
      }

      .hero-card li {
        margin: 10px 0;
        font-weight: 700;
        font-size: 0.98rem;
      }

      .section-title {
        text-align: center;
        margin-bottom: 42px;
      }

      .section-title h2 {
        font-size: clamp(2rem, 4vw, 3rem);
        color: var(--navy);
        margin-bottom: 10px;
        letter-spacing: -0.035em;
      }

      .section-title p {
        color: var(--muted);
        font-size: 1.05rem;
        max-width: 760px;
        margin: 0 auto;
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 22px;
      }

      .card {
        background: white;
        border-radius: 22px;
        padding: 28px;
        box-shadow: 0 10px 25px rgba(8, 59, 112, 0.08);
        border: 1px solid #d9eadf;
        border-top: 5px solid var(--green);
      }

      .card h3 {
        color: var(--navy);
        margin-bottom: 10px;
        font-size: 1.25rem;
      }

      .card p {
        color: var(--muted);
      }

      .process {
        background: white;
      }

      .process-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 18px;
      }

      .process-step {
        background: var(--cream);
        border: 1px solid var(--line);
        border-radius: 20px;
        padding: 24px;
      }

      .step-number {
        width: 38px;
        height: 38px;
        background: var(--navy);
        color: white;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        font-weight: 900;
        margin-bottom: 12px;
      }

      .process-step h3 {
        color: var(--navy);
        margin-bottom: 8px;
        font-size: 1.15rem;
      }

      .process-step p {
        color: var(--muted);
      }

      .gallery {
        background:
          radial-gradient(circle at top left, rgba(79, 143, 216, 0.13), transparent 34%),
          linear-gradient(180deg, #f4f8f4 0%, #eef7ef 100%);
      }

      .portfolio-slider {
        max-width: 1120px;
        margin: 0 auto;
        background: rgba(255, 255, 255, 0.84);
        border: 1px solid rgba(223, 233, 224, 0.95);
        border-radius: 30px;
        box-shadow: var(--shadow);
        padding: 26px;
      }

      .slider-stage {
        display: grid;
        grid-template-columns: 58px minmax(0, 1fr) 58px;
        gap: 18px;
        align-items: center;
      }

      .slider-arrow {
        width: 58px;
        min-width: 58px;
        height: 58px;
        border: none;
        border-radius: 999px;
        background: var(--navy);
        color: white;
        cursor: pointer;
        font-size: 2.35rem;
        line-height: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 12px 26px rgba(8, 59, 112, 0.24);
        transition: 0.2s ease;
      }

      .slider-arrow:hover {
        background: var(--green);
        transform: translateY(-2px);
      }

      .slider-window {
        background: #f7faf6;
        border-radius: 24px;
        height: min(58vw, 560px);
        min-height: 430px;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
      }

      .main-slide-link {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        height: 100%;
      }

      #main-slide-image {
        width: 100%;
        height: 100%;
        object-fit: contain;
        display: block;
      }

      .slider-bottom {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 18px;
        align-items: center;
        margin-top: 22px;
      }

      .slide-title {
        color: var(--navy);
        font-size: 1.5rem;
        font-weight: 900;
        letter-spacing: -0.02em;
      }

      .slide-description {
        color: var(--muted);
        margin-top: 3px;
        font-size: 1rem;
      }

      .slide-count {
        color: var(--green);
        font-weight: 900;
        font-size: 0.95rem;
        margin-top: 6px;
      }

      .open-photo {
        min-height: 48px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 12px 16px;
        border-radius: 13px;
        background: var(--green-soft);
        color: var(--navy);
        font-weight: 900;
        border: 1px solid #d9eadf;
        transition: 0.2s ease;
        white-space: nowrap;
      }

      .open-photo:hover {
        background: var(--blue);
        color: white;
      }

      .dot-row {
        display: flex;
        justify-content: center;
        gap: 10px;
        margin-top: 20px;
      }

      .dot {
        width: 14px;
        height: 14px;
        border-radius: 999px;
        border: none;
        background: #bacabb;
        cursor: pointer;
        transition: 0.2s ease;
      }

      .dot.active {
        width: 34px;
        background: var(--navy);
      }

      .gallery-note {
        max-width: 980px;
        margin: 20px auto 0;
        text-align: center;
        color: var(--muted);
        font-size: 0.98rem;
      }

      .about {
        background: white;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 48px;
        align-items: center;
      }

      .about h2 {
        color: var(--navy);
        font-size: clamp(2rem, 4vw, 2.7rem);
        margin-bottom: 16px;
        letter-spacing: -0.035em;
      }

      .about p {
        color: var(--muted);
        font-size: 1.05rem;
      }

      .about-list {
        margin-top: 20px;
        list-style: none;
        display: grid;
        gap: 10px;
      }

      .about-list li {
        color: var(--text);
        font-weight: 700;
      }

      .about-logo-wrap {
        background: linear-gradient(135deg, var(--green-soft), var(--blue-light));
        border-radius: 28px;
        padding: 35px;
        display: flex;
        justify-content: center;
        align-items: center;
        box-shadow: var(--shadow);
      }

      .about-logo-wrap img {
        width: 100%;
        max-width: 400px;
        height: auto;
        object-fit: contain;
      }

      .service-area {
        background: linear-gradient(135deg, var(--blue-light), var(--green-soft));
        text-align: center;
      }

      .towns {
        max-width: 850px;
        margin: 20px auto 0;
        font-weight: 900;
        color: var(--green);
        font-size: 1.15rem;
      }

      .faq {
        background: white;
      }

      .faq-grid {
        max-width: 980px;
        margin: 0 auto;
        display: grid;
        gap: 16px;
      }

      .faq-item {
        background: var(--cream);
        border: 1px solid var(--line);
        border-radius: 18px;
        padding: 22px;
      }

      .faq-item h3 {
        color: var(--navy);
        margin-bottom: 8px;
        font-size: 1.12rem;
      }

      .faq-item p {
        color: var(--muted);
      }

      .contact {
        background:
          radial-gradient(circle at top right, rgba(79, 143, 216, 0.25), transparent 30%),
          linear-gradient(135deg, var(--navy), var(--green-dark));
        color: white;
        text-align: center;
      }

      .contact h2 {
        font-size: clamp(2rem, 4vw, 3rem);
        margin-bottom: 14px;
        letter-spacing: -0.035em;
      }

      .contact p {
        max-width: 740px;
        margin: 0 auto 24px;
        font-size: 1.05rem;
      }

      .contact-info {
        max-width: 600px;
        margin: 0 auto 10px;
        padding: 28px;
        background: rgba(255, 255, 255, 0.12);
        border: 1px solid rgba(255, 255, 255, 0.24);
        border-radius: 22px;
        box-shadow: 0 12px 28px rgba(0, 0, 0, 0.12);
      }

      .contact-info p {
        margin: 8px auto;
      }

      .contact-info a {
        color: white;
        font-weight: 900;
        text-decoration: underline;
      }

      .contact-actions {
        display: flex;
        gap: 12px;
        justify-content: center;
        flex-wrap: wrap;
        margin-top: 18px;
      }

      .contact-button,
      .review-button {
        min-height: 48px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 12px 18px;
        border-radius: 12px;
        background: white;
        color: var(--navy) !important;
        font-weight: 900;
        text-decoration: none !important;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.14);
        transition: 0.2s ease;
      }

      .contact-button:hover,
      .review-button:hover {
        background: var(--blue);
        color: white !important;
        transform: translateY(-2px);
      }

      footer {
        background: #082b1a;
        color: white;
        text-align: center;
        padding: 24px 7%;
        font-size: 0.95rem;
      }

      @media (max-width: 1050px) {
        header {
          flex-direction: column;
          gap: 12px;
        }

        .brand-wrap {
          justify-content: center;
        }

        nav {
          flex-wrap: wrap;
          justify-content: center;
          gap: 14px;
        }

        .hero,
        .about {
          grid-template-columns: 1fr;
        }

        .hero {
          padding: 58px 7%;
          background:
            linear-gradient(rgba(8, 59, 112, 0.84), rgba(15, 61, 34, 0.82)),
            url("/Truck.webp");
          background-size: cover;
          background-position: center;
        }

        .grid {
          grid-template-columns: repeat(2, 1fr);
        }

        .process-grid {
          grid-template-columns: repeat(2, 1fr);
        }

        .slider-window {
          height: min(62vw, 500px);
          min-height: 380px;
        }
      }

      @media (max-width: 650px) {
        header {
          position: static;
          padding: 12px 5%;
          gap: 10px;
        }

        .brand-wrap {
          width: 100%;
          justify-content: space-between;
          gap: 10px;
        }

        .brand {
          gap: 9px;
        }

        .brand img {
          width: 46px;
          height: 46px;
        }

        .brand-text strong {
          font-size: 0.98rem;
        }

        .brand-text span {
          font-size: 0.74rem;
        }

        .header-phone {
          min-height: 44px;
          font-size: 0.84rem;
          padding: 8px 10px;
          border-radius: 11px;
        }

        nav {
          width: 100%;
          overflow-x: auto;
          justify-content: flex-start;
          gap: 16px;
          font-size: 0.82rem;
          padding: 4px 0 2px;
          scrollbar-width: none;
        }

        nav::-webkit-scrollbar {
          display: none;
        }

        nav a {
          min-height: 44px;
          display: inline-flex;
          align-items: center;
          white-space: nowrap;
        }

        section {
          padding: 54px 5%;
          scroll-margin-top: 20px;
        }

        .hero {
          padding: 42px 5%;
          min-height: auto;
          gap: 28px;
          grid-template-columns: 1fr;
          background:
            linear-gradient(rgba(8, 59, 112, 0.86), rgba(15, 61, 34, 0.86)),
            url("/Truck.webp");
          background-size: cover;
          background-position: center;
        }

        .eyebrow {
          font-size: 0.88rem;
          margin-bottom: 14px;
        }

        .hero h1 {
          font-size: clamp(2rem, 11vw, 2.55rem);
          line-height: 1.08;
          margin-bottom: 16px;
        }

        .hero p {
          font-size: 0.98rem;
          line-height: 1.62;
          margin-bottom: 22px;
        }

        .buttons {
          flex-direction: column;
          gap: 10px;
        }

        .btn {
          text-align: center;
          width: 100%;
          border-radius: 12px;
          padding: 13px 18px;
        }

        .hero-card {
          padding: 22px 18px;
          border-radius: 20px;
        }

        .hero-card img {
          width: 92px;
        }

        .hero-card h2 {
          font-size: 1.25rem;
        }

        .hero-card li {
          font-size: 0.92rem;
        }

        .section-title {
          margin-bottom: 28px;
        }

        .section-title h2 {
          font-size: 2rem;
        }

        .section-title p {
          font-size: 0.96rem;
        }

        .grid,
        .process-grid {
          grid-template-columns: 1fr;
          gap: 14px;
        }

        .card,
        .process-step {
          padding: 22px;
          border-radius: 18px;
        }

        .portfolio-slider {
          padding: 14px;
          border-radius: 22px;
          box-shadow: 0 12px 28px rgba(8, 59, 112, 0.1);
        }

        .slider-stage {
          grid-template-columns: 42px minmax(0, 1fr) 42px;
          gap: 8px;
        }

        .slider-arrow {
          width: 42px;
          min-width: 42px;
          height: 42px;
          font-size: 1.65rem;
          box-shadow: 0 8px 18px rgba(8, 59, 112, 0.2);
        }

        .slider-window {
          min-height: 0;
          height: 64vw;
          max-height: 340px;
          border-radius: 16px;
        }

        .slider-bottom {
          grid-template-columns: 1fr;
          text-align: center;
          gap: 14px;
          margin-top: 16px;
        }

        .slide-title {
          font-size: 1.25rem;
        }

        .slide-description {
          font-size: 0.92rem;
        }

        .open-photo {
          width: 100%;
          padding: 11px 14px;
        }

        .dot-row {
          gap: 8px;
          margin-top: 16px;
        }

        .dot {
          min-width: 18px;
          min-height: 18px;
        }

        .about {
          grid-template-columns: 1fr;
          gap: 28px;
        }

        .about-logo-wrap {
          padding: 24px;
          border-radius: 22px;
        }

        .contact-info {
          padding: 20px;
          border-radius: 18px;
        }

        .contact-actions {
          flex-direction: column;
        }

        .contact-button,
        .review-button {
          width: 100%;
        }

        footer {
          font-size: 0.84rem;
          padding: 22px 5%;
        }
      }
    </style>
  </head>

  <body>
    <header>
      <div class="brand-wrap">
        <a class="brand" href="#" aria-label="Lakeside Landscaping LLC home">
          <img src={logo} alt="Lakeside Landscaping LLC logo" width="58" height="58" />
          <div class="brand-text">
            <strong>Lakeside</strong>
