---
const businessName = "Lakeside Landscaping LLC";
const ownerName = "Charles Oberman";
const phone = "(862) 241-9371";
const phoneHref = "+18622419371";
const email = "lakesidelandscaping25@gmail.com";
const location = "Morris County and surrounding areas in New Jersey";
const logo = "/LLLogo.png";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="icon" type="image/png" href="/LLLogo.png" />
    <link rel="apple-touch-icon" href="/LLLogo.png" />

    <title>{businessName} | Lawn Care & Landscaping in Morris County, NJ</title>
    <meta
      name="description"
      content="Lakeside Landscaping LLC provides lawn mowing, landscaping projects, hardscaping, weeding, trimming, planting, leaf removal, cleanups, and snow removal in Morris County and surrounding areas in New Jersey."
    />

    <style>
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      :root {
        --navy: #0b3d73;
        --green: #1f6f2a;
        --dark-green: #123f1f;
        --lake-blue: #4f8fd8;
        --light-blue: #dceefe;
        --soft-green: #eef7ef;
        --white: #ffffff;
        --text: #1f2933;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: Arial, sans-serif;
        color: var(--text);
        background: var(--soft-green);
        line-height: 1.6;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      header {
        background: var(--white);
        color: var(--navy);
        padding: 14px 7%;
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: sticky;
        top: 0;
        z-index: 10;
        box-shadow: 0 4px 18px rgba(11, 61, 115, 0.12);
      }

      .brand {
        display: flex;
        align-items: center;
        gap: 12px;
      }

      .brand img {
        width: 62px;
        height: 62px;
        object-fit: contain;
      }

      .brand-text {
        display: flex;
        flex-direction: column;
        line-height: 1.1;
      }

      .brand-text strong {
        font-size: 1.2rem;
        color: var(--navy);
      }

      .brand-text span {
        font-size: 0.85rem;
        color: var(--green);
        font-weight: 700;
      }

      nav {
        display: flex;
        gap: 22px;
        font-size: 0.95rem;
        font-weight: 700;
      }

      nav a:hover {
        color: var(--green);
      }

      .hero {
        min-height: 82vh;
        padding: 90px 7%;
        display: grid;
        grid-template-columns: 1.05fr 0.95fr;
        gap: 45px;
        align-items: center;
        background:
          linear-gradient(rgba(11, 61, 115, 0.72), rgba(18, 63, 31, 0.78)),
          url("/Truck.png");
        background-size: cover;
        background-position: 35% center;
        color: white;
      }

      .hero h1 {
        font-size: clamp(2.3rem, 5vw, 4.6rem);
        line-height: 1.05;
        margin-bottom: 20px;
      }

      .hero p {
        font-size: 1.15rem;
        max-width: 650px;
        margin-bottom: 28px;
      }

      .buttons {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
      }

      .btn {
        padding: 13px 22px;
        border-radius: 999px;
        font-weight: 800;
        display: inline-block;
      }

      .btn-primary {
        background: var(--lake-blue);
        color: white;
        box-shadow: 0 8px 20px rgba(79, 143, 216, 0.28);
      }

      .btn-primary:hover {
        background: var(--navy);
      }

      .btn-secondary {
        border: 2px solid white;
        color: white;
      }

      .btn-secondary:hover {
        background: white;
        color: var(--navy);
      }

      .hero-card {
        background: rgba(255, 255, 255, 0.96);
        color: var(--text);
        padding: 34px;
        border-radius: 24px;
        box-shadow: 0 22px 50px rgba(0, 0, 0, 0.2);
        border-top: 8px solid var(--lake-blue);
      }

      .hero-card img {
        width: 150px;
        display: block;
        margin: 0 auto 18px;
      }

      .hero-card h2 {
        margin-bottom: 14px;
        color: var(--navy);
        text-align: center;
      }

      .hero-card ul {
        list-style: none;
      }

      .hero-card li {
        margin: 10px 0;
        font-weight: 600;
      }

      section {
        padding: 72px 7%;
      }

      .section-title {
        text-align: center;
        margin-bottom: 38px;
      }

      .section-title h2 {
        font-size: 2.2rem;
        color: var(--navy);
        margin-bottom: 10px;
      }

      .section-title p {
        color: #52616b;
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 22px;
      }

      .card {
        background: white;
        border-radius: 20px;
        padding: 28px;
        box-shadow: 0 10px 25px rgba(11, 61, 115, 0.08);
        border: 1px solid #d9eadf;
        border-top: 5px solid var(--green);
      }

      .card h3 {
        color: var(--navy);
        margin-bottom: 10px;
      }

      .gallery {
        background: var(--soft-green);
      }

      .gallery-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 22px;
      }

      .gallery-card {
        background: white;
        border-radius: 20px;
        min-height: 220px;
        display: flex;
        justify-content: center;
        align-items: center;
        text-align: center;
        padding: 28px;
        color: var(--navy);
        font-weight: 800;
        border: 2px dashed #b8d9c0;
      }

      .about {
        background: white;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 45px;
        align-items: center;
      }

      .about h2 {
        color: var(--navy);
        font-size: 2.1rem;
        margin-bottom: 16px;
      }

      .about-logo-wrap {
        background: linear-gradient(135deg, var(--soft-green), var(--light-blue));
        border-radius: 26px;
        padding: 35px;
        display: flex;
        justify-content: center;
        align-items: center;
        box-shadow: 0 14px 35px rgba(0, 0, 0, 0.1);
      }

      .about-logo-wrap img {
        width: 100%;
        max-width: 420px;
        object-fit: contain;
      }

      .service-area {
        background: linear-gradient(135deg, var(--light-blue), var(--soft-green));
        text-align: center;
      }

      .towns {
        max-width: 850px;
        margin: 20px auto 0;
        font-weight: 800;
        color: var(--green);
      }

      .contact {
        background: linear-gradient(135deg, var(--navy), var(--dark-green));
        color: white;
        text-align: center;
      }

      .contact h2 {
        font-size: 2.2rem;
        margin-bottom: 14px;
      }

      .contact p {
        max-width: 700px;
        margin: 0 auto 24px;
      }

      .contact-info {
        max-width: 520px;
        margin: 0 auto 26px;
        padding: 22px;
        background: rgba(255, 255, 255, 0.12);
        border: 1px solid rgba(255, 255, 255, 0.22);
        border-radius: 18px;
      }

      .contact-info p {
        margin: 6px auto;
      }

      .contact-info a {
        color: white;
        font-weight: 800;
        text-decoration: underline;
      }

      footer {
        background: #082b1a;
        color: white;
        text-align: center;
        padding: 24px 7%;
        font-size: 0.9rem;
      }

      @media (max-width: 850px) {
        header {
          flex-direction: column;
          gap: 12px;
        }

        nav {
          flex-wrap: wrap;
          justify-content: center;
        }

        .hero,
        .about {
          grid-template-columns: 1fr;
        }

        .grid,
        .gallery-grid {
          grid-template-columns: 1fr;
        }

        .hero {
          padding-top: 70px;
          background-position: center;
        }

        .brand img {
          width: 54px;
          height: 54px;
        }
      }
    </style>
  </head>

  <body>
    <header>
      <a class="brand" href="#">
        <img src={logo} alt="Lakeside Landscaping LLC logo" />
        <div class="brand-text">
          <strong>Lakeside</strong>
          <span>Landscaping LLC</span>
        </div>
      </a>

      <nav>
        <a href="#services">Services</a>
        <a href="#gallery">Gallery</a>
        <a href="#about">About</a>
        <a href="#area">Service Area</a>
        <a href="#contact">Contact</a>
      </nav>
    </header>

    <main>
      <section class="hero">
        <div>
          <h1>Lawn Care, Landscaping & Snow Removal in Morris County, NJ</h1>
          <p>
            Owned by {ownerName}, Lakeside Landscaping LLC provides dependable lawn mowing,
            landscaping projects, hardscaping, weeding, trimming, planting, leaf removal,
            cleanups, and snow removal for residential and commercial properties.
          </p>

          <div class="buttons">
            <a class="btn btn-primary" href={`tel:${phoneHref}`}>Call for a Free Estimate</a>
            <a class="btn btn-secondary" href="#services">View Services</a>
          </div>
        </div>

        <div class="hero-card">
          <img src={logo} alt="Lakeside Landscaping LLC logo" />
          <h2>Reliable Outdoor Property Care</h2>
          <ul>
            <li>✓ Free estimates available</li>
            <li>✓ Residential and commercial service</li>
            <li>✓ Lawn mowing and maintenance</li>
            <li>✓ Landscaping, planting, and cleanups</li>
            <li>✓ Leaf removal and snow removal</li>
          </ul>
        </div>
      </section>

      <section id="services">
        <div class="section-title">
          <h2>Our Services</h2>
          <p>Outdoor services to keep your property clean, maintained, and ready for every season.</p>
        </div>

        <div class="grid">
          <div class="card">
            <h3>Lawn Mowing</h3>
            <p>Routine lawn mowing, edging, trimming, and blowing for a clean, maintained property.</p>
          </div>

          <div class="card">
            <h3>Landscaping Projects</h3>
            <p>Landscape refreshes, yard improvements, mulch, soil, planting beds, and general outdoor project work.</p>
          </div>

          <div class="card">
            <h3>Hardscaping</h3>
            <p>Hardscape-related outdoor improvements such as stone, edging, walkways, and similar projects.</p>
          </div>

          <div class="card">
            <h3>Weeding & Trimming</h3>
            <p>Weeding, trimming, hedge care, shrub shaping, and cleanup around landscaped areas.</p>
          </div>

          <div class="card">
            <h3>Planting</h3>
            <p>Planting flowers, shrubs, and greenery to improve the look of your outdoor space.</p>
          </div>

          <div class="card">
            <h3>Leaf Removal & Cleanups</h3>
            <p>Seasonal cleanups, fall leaf removal, yard debris removal, and property cleanup services.</p>
          </div>

          <div class="card">
            <h3>Snow Removal</h3>
            <p>Snow removal services to help keep residential and commercial properties accessible in winter.</p>
          </div>

          <div class="card">
            <h3>Residential Service</h3>
            <p>Lawn and landscaping care for homeowners looking for reliable property maintenance.</p>
          </div>

          <div class="card">
            <h3>Commercial Service</h3>
            <p>Outdoor maintenance and seasonal services for businesses and commercial properties.</p>
          </div>
        </div>
      </section>

      <section id="gallery" class="gallery">
        <div class="section-title">
          <h2>Project Gallery</h2>
          <p>Photos of completed lawn care and landscaping projects will be added soon.</p>
        </div>

        <div class="gallery-grid">
          <div class="gallery-card">Before & After Photos Coming Soon</div>
          <div class="gallery-card">Landscaping Projects Coming Soon</div>
          <div class="gallery-card">Seasonal Cleanup Photos Coming Soon</div>
        </div>
      </section>

      <section id="about" class="about">
        <div>
          <h2>Locally Owned Landscaping Service</h2>
          <p>
            Lakeside Landscaping LLC is locally owned by {ownerName} and focused on honest
            communication, reliable scheduling, and clean outdoor work. Whether you need
            routine lawn care, a seasonal cleanup, landscaping help, or snow removal, we help
            keep your property looking its best.
          </p>
          <br />
          <p>
            Contact Charles today for a free estimate and tell us what your property needs.
          </p>
        </div>

        <div class="about-logo-wrap">
          <img src={logo} alt="Lakeside Landscaping LLC logo" />
        </div>
      </section>

      <section id="area" class="service-area">
        <div class="section-title">
          <h2>Service Area</h2>
          <p>Serving residential and commercial customers in New Jersey.</p>
          <div class="towns">
            Serving Morris County and surrounding areas in New Jersey.
          </div>
        </div>
      </section>

      <section id="contact" class="contact">
        <h2>Contact Charles for a Free Estimate</h2>
        <p>
          Call, text, or email {ownerName} at Lakeside Landscaping LLC to schedule
          lawn mowing, landscaping, cleanups, hardscaping, leaf removal, or snow removal services.
        </p>

        <div class="contact-info">
          <p><strong>Owner:</strong> {ownerName}</p>
          <p><strong>Phone:</strong> <a href={`tel:${phoneHref}`}>{phone}</a></p>
          <p><strong>Email:</strong> <a href={`mailto:${email}`}>{email}</a></p>
        </div>

        <div class="buttons" style="justify-content: center;">
          <a class="btn btn-primary" href={`tel:${phoneHref}`}>Call or Text {phone}</a>
          <a class="btn btn-secondary" href={`mailto:${email}`}>Email Charles</a>
        </div>
      </section>
    </main>

    <footer>
      © {new Date().getFullYear()} {businessName}. All rights reserved. Serving {location}.
    </footer>
  </body>
</html>
