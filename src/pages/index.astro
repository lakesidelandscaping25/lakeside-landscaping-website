---
const businessName = "Lakeside Landscaping LLC";
const ownerName = "Charlie Oberman";
const phone = "(862) 241-9371";
const phoneHref = "+18622419371";
const email = "lakesidelandscaping25@gmail.com";
const location = "Morris County and surrounding areas in New Jersey";
const logo = "/LLLogo.png";
const reviewLink = "https://g.page/r/Cc8fX3vmupGEEAE/review";
const siteUrl = "https://lakeside-landscaping-llc.com/";
const seoTitle = "Lakeside Landscaping LLC | Morris County, NJ";
const seoDescription = "Lakeside Landscaping LLC provides lawn mowing, cleanups, planting, hardscaping, leaf removal, and snow removal in Morris County, NJ.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{seoTitle}</title>
    <meta name="description" content={seoDescription} />
    <link rel="canonical" href={siteUrl} />

    <link rel="icon" type="image/png" href="/LLLogo.png" />
    <link rel="apple-touch-icon" href="/LLLogo.png" />
    <link rel="preload" as="image" href="/Truck.webp" />

    <meta property="og:title" content={seoTitle} />
    <meta property="og:description" content={seoDescription} />
    <meta property="og:image" content="https://lakeside-landscaping-llc.com/LLLogo.png" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={businessName} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seoTitle} />
    <meta name="twitter:description" content={seoDescription} />
    <meta name="twitter:image" content="https://lakeside-landscaping-llc.com/LLLogo.png" />

    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "LandscapingBusiness",
