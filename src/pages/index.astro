        <a class="header-phone" href={`tel:${phoneHref}`} aria-label={`Call Lakeside Landscaping LLC at ${phone}`}>
          {phone}
        </a>
      </div>

      <nav aria-label="Main navigation">
        <a href="#services">Services</a>
        <a href="#process">Process</a>
        <a href="#gallery">Gallery</a>
        <a href="#about">About</a>
        <a href="#area">Service Area</a>
        <a href="#contact">Contact</a>
      </nav>
    </header>

    <main>
      <section class="hero">
        <div>
          <div class="eyebrow">Free estimates available</div>
          <h1>Reliable Landscaping and Property Care in Morris County, NJ</h1>
          <p>
            Lakeside Landscaping LLC helps homeowners and businesses keep outdoor spaces clean,
