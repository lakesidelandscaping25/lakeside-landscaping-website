        "logo": "https://lakeside-landscaping-llc.com/LLLogo.png",
        "image": "https://lakeside-landscaping-llc.com/LLLogo.png",
        "telephone": "+18622419371",
        "email": "lakesidelandscaping25@gmail.com",
        "founder": {
          "@type": "Person",
          "name": "Charlie Oberman"
        },
        "areaServed": {
          "@type": "AdministrativeArea",
          "name": "Morris County, NJ"
        },
        "address": {
          "@type": "PostalAddress",
          "addressRegion": "NJ",
          "addressCountry": "US"
        },
        "description": "Lakeside Landscaping LLC provides lawn mowing, landscaping, cleanups, planting, hardscaping, leaf removal, and snow removal in Morris County, NJ.",
        "priceRange": "$$",
        "sameAs": [
          "https://g.page/r/Cc8fX3vmupGEEAE/review"
        ],
        "hasOfferCatalog": {
          "@type": "OfferCatalog",
          "name": "Landscaping Services",
          "itemListElement": [
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Lawn Mowing"
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Landscaping Projects"
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Hardscaping"
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Leaf Removal and Cleanups"
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Snow Removal"
              }
            }
          ]
        }
      }
    </script>

    <style>
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      :root {
        --navy: #0b3d73;
        --green: #1f6f2a;
        --dark-green: #0f3d22;
        --lake-blue: #4f8fd8;
        --light-blue: #dceefe;
        --soft-green: #eef7ef;
        --cream: #f8fbf7;
        --white: #ffffff;
        --text: #1f2933;
        --muted: #53616c;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: Arial, sans-serif;
        color: var(--text);
        background: var(--cream);
        line-height: 1.6;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      header {
        background: rgba(255, 255, 255, 0.96);
        color: var(--navy);
        padding: 12px 7%;
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: sticky;
        top: 0;
        z-index: 20;
        box-shadow: 0 4px 18px rgba(11, 61, 115, 0.12);
        backdrop-filter: blur(10px);
      }

      .brand-wrap {
        display: flex;
        align-items: center;
        gap: 24px;
      }

      .brand {
        display: flex;
        align-items: center;
        gap: 12px;
      }

      .brand img {
        width: 58px;
        height: 58px;
        object-fit: contain;
      }

      .brand-text {
        display: flex;
        flex-direction: column;
        line-height: 1.1;
      }

      .brand-text strong {
        font-size: 1.2rem;
        color: var(--navy);
      }

      .brand-text span {
        font-size: 0.85rem;
        color: var(--green);
        font-weight: 800;
      }

      .header-phone {
        color: var(--navy);
        font-weight: 900;
        font-size: 1rem;
        padding: 10px 14px;
        border-radius: 12px;
        background: var(--soft-green);
        border: 1px solid #d9eadf;
        transition: 0.2s ease;
        white-space: nowrap;
      }

      .header-phone:hover {
        background: var(--lake-blue);
        color: white;
        transform: translateY(-1px);
      }

      nav {
        display: flex;
        gap: 22px;
        font-size: 0.95rem;
        font-weight: 800;
      }

      nav a:hover {
        color: var(--green);
      }

      .hero {
        min-height: 82vh;
        padding: 74px 7%;
        display: grid;
        grid-template-columns: minmax(0, 1fr) 420px;
        gap: 56px;
        align-items: center;
        background:
          linear-gradient(
            90deg,
            rgba(8, 35, 62, 0.88) 0%,
            rgba(9, 55, 35, 0.76) 52%,
            rgba(9, 55, 35, 0.58) 100%
          ),
          url("/Truck.webp");
        background-size: cover;
        background-position: 38% center;
        color: white;
      }

      .hero h1 {
        font-size: clamp(2.5rem, 4.5vw, 4.35rem);
        line-height: 1.05;
        letter-spacing: -0.04em;
        margin-bottom: 22px;
        max-width: 760px;
      }

      .hero p {
        font-size: 1.08rem;
        max-width: 620px;
        margin-bottom: 30px;
        line-height: 1.75;
        color: rgba(255, 255, 255, 0.92);
      }

      .buttons {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
      }

      .btn {
        padding: 13px 22px;
        border-radius: 12px;
        font-weight: 900;
        display: inline-block;
        transition: 0.2s ease;
      }

      .btn-primary {
        background: var(--lake-blue);
        color: white;
        box-shadow: 0 8px 20px rgba(79, 143, 216, 0.28);
      }

      .btn-primary:hover {
        background: var(--navy);
        transform: translateY(-2px);
      }

      .btn-secondary {
        border: 2px solid rgba(255, 255, 255, 0.9);
        color: white;
      }

      .btn-secondary:hover {
        background: white;
        color: var(--navy);
        transform: translateY(-2px);
      }

      .hero-card {
        background: rgba(255, 255, 255, 0.96);
        color: var(--text);
        padding: 30px;
        border-radius: 22px;
        box-shadow: 0 18px 44px rgba(0, 0, 0, 0.22);
        border: 1px solid rgba(255, 255, 255, 0.7);
        border-top: 6px solid var(--lake-blue);
      }

      .hero-card img {
        width: 118px;
        height: auto;
        display: block;
        margin: 0 auto 18px;
      }

      .hero-card h2 {
        margin-bottom: 18px;
        color: var(--navy);
        text-align: center;
        font-size: 1.45rem;
        line-height: 1.25;
      }

      .hero-card ul {
        list-style: none;
      }

      .hero-card li {
        margin: 10px 0;
        font-weight: 700;
        font-size: 0.98rem;
      }

      section {
        padding: 76px 7%;
      }

      .section-title {
        text-align: center;
        margin-bottom: 42px;
      }

      .section-title h2 {
        font-size: clamp(2rem, 4vw, 3rem);
        color: var(--navy);
        margin-bottom: 10px;
      }

      .section-title p {
        color: var(--muted);
        font-size: 1.05rem;
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 22px;
      }

      .card {
        background: white;
        border-radius: 22px;
        padding: 28px;
        box-shadow: 0 10px 25px rgba(11, 61, 115, 0.08);
        border: 1px solid #d9eadf;
        border-top: 5px solid var(--green);
      }

      .card h3 {
        color: var(--navy);
        margin-bottom: 10px;
        font-size: 1.25rem;
      }

      .card p {
        color: var(--muted);
      }

      .gallery {
        background: #f4f8f4;
      }

      .gallery-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 28px;
        max-width: 1180px;
        margin: 0 auto;
      }

      .gallery-photo-card {
        background: white;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 14px 34px rgba(11, 61, 115, 0.11);
        border: 1px solid #dfe9e0;
      }

      .gallery-photo-card img {
        width: 100%;
        height: 360px;
        display: block;
        object-fit: cover;
        background: #f8f8f8;
      }

      .gallery-caption {
        padding: 22px 24px 26px;
      }

      .gallery-caption h3 {
        color: var(--navy);
        margin-bottom: 8px;
        font-size: 1.45rem;
      }

      .gallery-caption p {
        color: var(--muted);
        font-size: 1rem;
        line-height: 1.65;
      }

      .about {
        background: white;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 48px;
        align-items: center;
      }

      .about h2 {
        color: var(--navy);
        font-size: clamp(2rem, 4vw, 2.7rem);
        margin-bottom: 16px;
      }

      .about p {
        color: var(--muted);
        font-size: 1.05rem;
      }

      .about-logo-wrap {
        background: linear-gradient(135deg, var(--soft-green), var(--light-blue));
        border-radius: 28px;
        padding: 35px;
        display: flex;
        justify-content: center;
        align-items: center;
        box-shadow: 0 14px 35px rgba(0, 0, 0, 0.1);
      }

      .about-logo-wrap img {
        width: 100%;
        max-width: 400px;
        height: auto;
        object-fit: contain;
      }

      .service-area {
        background: linear-gradient(135deg, var(--light-blue), var(--soft-green));
        text-align: center;
      }

      .towns {
        max-width: 850px;
        margin: 20px auto 0;
        font-weight: 900;
        color: var(--green);
        font-size: 1.15rem;
      }

      .contact {
        background: linear-gradient(135deg, var(--navy), var(--dark-green));
        color: white;
        text-align: center;
      }

      .contact h2 {
        font-size: clamp(2rem, 4vw, 3rem);
        margin-bottom: 14px;
      }

      .contact p {
        max-width: 740px;
        margin: 0 auto 24px;
        font-size: 1.05rem;
      }

      .contact-info {
        max-width: 560px;
        margin: 0 auto 10px;
        padding: 26px;
        background: rgba(255, 255, 255, 0.12);
        border: 1px solid rgba(255, 255, 255, 0.24);
        border-radius: 20px;
        box-shadow: 0 12px 28px rgba(0, 0, 0, 0.12);
      }

      .contact-info p {
        margin: 8px auto;
      }

      .contact-info a {
        color: white;
        font-weight: 900;
        text-decoration: underline;
      }

      .review-button {
        display: inline-block;
        margin-top: 18px;
        padding: 12px 18px;
        border-radius: 12px;
        background: white;
        color: var(--navy) !important;
        font-weight: 900;
        text-decoration: none !important;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.14);
        transition: 0.2s ease;
      }

      .review-button:hover {
        background: var(--lake-blue);
        color: white !important;
        transform: translateY(-2px);
      }

      footer {
        background: #082b1a;
        color: white;
        text-align: center;
        padding: 24px 7%;
        font-size: 0.95rem;
      }

      @media (max-width: 1050px) {
        header {
          flex-direction: column;
          gap: 12px;
        }

        .brand-wrap {
          justify-content: center;
        }

        nav {
          flex-wrap: wrap;
          justify-content: center;
          gap: 14px;
        }

        .hero,
        .about {
          grid-template-columns: 1fr;
        }

        .hero {
          padding: 58px 7%;
          background:
            linear-gradient(rgba(8, 35, 62, 0.84), rgba(9, 55, 35, 0.82)),
            url("/Truck.webp");
          background-size: cover;
          background-position: center;
        }

        .grid {
          grid-template-columns: repeat(2, 1fr);
        }
      }

      @media (max-width: 650px) {
        header {
          padding: 12px 5%;
        }

        .brand-wrap {
          flex-direction: column;
          gap: 8px;
        }

        .brand img {
          width: 52px;
          height: 52px;
        }

        .brand-text strong {
          font-size: 1rem;
        }

        .brand-text span {
          font-size: 0.78rem;
        }

        .header-phone {
          font-size: 0.95rem;
          padding: 8px 12px;
        }

        nav {
          font-size: 0.84rem;
          gap: 10px;
        }

        .hero {
          padding: 46px 5%;
          min-height: auto;
          gap: 30px;
          grid-template-columns: 1fr;
          background:
            linear-gradient(rgba(8, 35, 62, 0.84), rgba(9, 55, 35, 0.82)),
            url("/Truck.webp");
          background-size: cover;
          background-position: center;
        }

        .hero h1 {
          font-size: 2.15rem;
          line-height: 1.08;
        }

        .hero p {
          font-size: 1rem;
          line-height: 1.65;
        }

        .buttons {
          flex-direction: column;
        }

        .btn {
          text-align: center;
          width: 100%;
          border-radius: 12px;
        }

        .hero-card {
          padding: 24px 20px;
        }

        .hero-card img {
          width: 105px;
        }

        .hero-card h2 {
          font-size: 1.35rem;
        }

        section {
          padding: 58px 5%;
        }

        .grid,
        .gallery-grid {
          grid-template-columns: 1fr;
        }

        .gallery-photo-card img {
          height: auto;
        }

        .gallery-caption {
          padding: 20px;
        }

        .about-logo-wrap {
          padding: 24px;
        }

        .contact-info {
          padding: 20px;
        }

        .review-button {
          width: 100%;
        }

        footer {
          font-size: 0.85rem;
        }
      }
    </style>
  </head>

  <body>
    <header>
      <div class="brand-wrap">
        <a class="brand" href="#">
          <img src={logo} alt="Lakeside Landscaping LLC logo" />
          <div class="brand-text">
            <strong>Lakeside</strong>
            <span>Landscaping LLC</span>
          </div>
        </a>

        <a class="header-phone" href={`tel:${phoneHref}`}>
          {phone}
        </a>
      </div>

      <nav>
        <a href="#services">Services</a>
        <a href="#gallery">Gallery</a>
        <a href="#about">About</a>
        <a href="#area">Service Area</a>
        <a href="#contact">Contact</a>
      </nav>
    </header>

    <main>
      <section class="hero">
        <div>
          <h1>Reliable Landscaping and Property Care in Morris County, NJ</h1>
          <p>
            From weekly lawn mowing to seasonal cleanups, planting, hardscaping, and snow removal,
            Lakeside Landscaping LLC helps keep residential and commercial properties clean,
            maintained, and ready for every season.
          </p>

          <div class="buttons">
            <a class="btn btn-primary" href={`tel:${phoneHref}`}>Call for a Free Estimate</a>
            <a class="btn btn-secondary" href="#services">View Services</a>
          </div>
        </div>

        <div class="hero-card">
          <img src={logo} alt="Lakeside Landscaping LLC logo" />
          <h2>Reliable Outdoor Property Care</h2>
          <ul>
            <li>✓ Free estimates</li>
            <li>✓ Residential and commercial properties</li>
            <li>✓ Lawn mowing and routine maintenance</li>
            <li>✓ Planting, trimming, and cleanup work</li>
            <li>✓ Leaf removal and snow removal</li>
          </ul>
        </div>
      </section>

      <section id="services">
        <div class="section-title">
          <h2>Our Services</h2>
          <p>Outdoor services to keep your property clean, maintained, and ready for every season.</p>
        </div>

        <div class="grid">
          <div class="card">
            <h3>Lawn Mowing</h3>
            <p>Routine lawn mowing, edging, trimming, and blowing for a clean, maintained property.</p>
          </div>

          <div class="card">
            <h3>Landscaping Projects</h3>
            <p>Landscape refreshes, yard improvements, mulch, soil, planting beds, and general outdoor project work.</p>
          </div>

          <div class="card">
            <h3>Hardscaping</h3>
            <p>Hardscape-related outdoor improvements such as stone, edging, walkways, and similar projects.</p>
          </div>

          <div class="card">
            <h3>Weeding & Trimming</h3>
            <p>Weeding, trimming, hedge care, shrub shaping, and cleanup around landscaped areas.</p>
          </div>

          <div class="card">
            <h3>Planting</h3>
            <p>Planting flowers, shrubs, and greenery to improve the look of your outdoor space.</p>
          </div>

          <div class="card">
            <h3>Leaf Removal & Cleanups</h3>
            <p>Seasonal cleanups, fall leaf removal, yard debris removal, and property cleanup services.</p>
          </div>

          <div class="card">
            <h3>Snow Removal</h3>
            <p>Snow removal services to help keep residential and commercial properties accessible in winter.</p>
          </div>

          <div class="card">
            <h3>Residential Service</h3>
            <p>Lawn and landscaping care for homeowners looking for reliable property maintenance.</p>
          </div>

          <div class="card">
            <h3>Commercial Service</h3>
            <p>Outdoor maintenance and seasonal services for businesses and commercial properties.</p>
          </div>
        </div>
      </section>

      <section id="gallery" class="gallery">
        <div class="section-title">
          <h2>Project Gallery</h2>
          <p>Photos from recent landscaping, cleanup, and property maintenance projects.</p>
        </div>

        <div class="gallery-grid">
          <div class="gallery-photo-card">
            <img
              src="/BeforeAfter-Leaves.webp"
              alt="Before and after leaf cleanup project"
              loading="lazy"
              width="1200"
              height="800"
            />
            <div class="gallery-caption">
              <h3>Leaf Cleanup & Yard Clearing</h3>
              <p>Leaves, debris, and overgrown areas cleared for a cleaner outdoor space.</p>
            </div>
          </div>

          <div class="gallery-photo-card">
            <img
              src="/BeforeAfter-Flowers.webp"
              alt="Before and after flower bed landscaping project"
              loading="lazy"
              width="1200"
              height="800"
            />
            <div class="gallery-caption">
              <h3>Flower Bed Cleanup & Planting</h3>
              <p>Landscape refresh with trimming, cleanup, planting, and improved curb appeal.</p>
            </div>
          </div>

          <div class="gallery-photo-card">
            <img
              src="/BeforeAfter-Mulch.webp"
              alt="Before and after mulch landscaping project"
              loading="lazy"
              width="1200"
              height="800"
            />
            <div class="gallery-caption">
              <h3>Mulch & Bed Refresh</h3>
              <p>Fresh mulch and cleanup work to improve the look of landscaped areas.</p>
            </div>
          </div>

          <div class="gallery-photo-card">
            <img
              src="/Looking%20Down.webp"
              alt="Landscaping project view"
              loading="lazy"
              width="1200"
              height="800"
            />
            <div class="gallery-caption">
              <h3>Property Cleanup Work</h3>
              <p>Clean outdoor maintenance work for a neat and well-kept property.</p>
            </div>
          </div>

          <div class="gallery-photo-card">
            <img
              src="/Thumbs%20Up.webp"
              alt="Completed landscaping work"
              loading="lazy"
              width="1200"
              height="800"
            />
            <div class="gallery-caption">
              <h3>Completed Project</h3>
              <p>Finished landscaping and cleanup work completed with attention to detail.</p>
            </div>
          </div>
        </div>
      </section>

      <section id="about" class="about">
        <div>
          <h2>Locally Owned Landscaping Service</h2>
          <p>
            Lakeside Landscaping LLC is focused on honest communication, reliable scheduling,
            and clean outdoor work. Whether you need routine lawn care, a seasonal cleanup,
            landscaping help, or snow removal, we help keep your property looking its best.
          </p>
          <br />
          <p>
            Contact us today for a free estimate and tell us what your property needs.
          </p>
        </div>

        <div class="about-logo-wrap">
          <img src={logo} alt="Lakeside Landscaping LLC logo" loading="lazy" />
        </div>
      </section>

      <section id="area" class="service-area">
        <div class="section-title">
          <h2>Service Area</h2>
          <p>Serving residential and commercial customers in New Jersey.</p>
          <div class="towns">
            Serving Morris County and surrounding areas in New Jersey.
          </div>
        </div>
      </section>

      <section id="contact" class="contact">
        <h2>Contact Us for a Free Estimate</h2>
        <p>
          Call, text, or email Lakeside Landscaping LLC to schedule lawn mowing,
          landscaping, cleanups, hardscaping, leaf removal, or snow removal services.
        </p>

        <div class="contact-info">
          <p><strong>Owner:</strong> {ownerName}</p>
          <p><strong>Phone:</strong> <a href={`tel:${phoneHref}`}>{phone}</a></p>
          <p><strong>Email:</strong> <a href={`mailto:${email}`}>{email}</a></p>

          <a class="review-button" href={reviewLink} target="_blank" rel="noopener noreferrer">
            Leave a Google Review
          </a>
        </div>
      </section>
    </main>

    <footer>
      © {new Date().getFullYear()} {businessName}. All rights reserved. Serving {location}.
    </footer>
  </body>
</html>
